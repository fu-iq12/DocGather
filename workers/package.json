{
  "name": "docgather-workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bullstudio": "npx bullstudio -r redis://localhost:6380",
    "bullstudio:upstash": "npx dotenv-cli -- npx bullstudio -r %REDIS_URL%",
    "upload-test": "npx tsx ../scripts/test-upload.ts test-user@example.com ../test.png",
    "docker:rebuild": "docker-compose build worker"
  },
  "dependencies": {
    "@langfuse/client": "^5.0.1",
    "@langfuse/otel": "^5.0.1",
    "@langfuse/tracing": "^5.0.1",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@prettier/sync": "^0.6.1",
    "@supabase/supabase-js": "^2.49.0",
    "bullmq": "^5.34.0",
    "express": "^5.2.1",
    "ioredis": "^5.4.0",
    "lodash.merge": "^4.6.2",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.8.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zod-deep-partial": "^1.4.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
